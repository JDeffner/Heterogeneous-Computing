{
  "name": "assisted-living-smarthome",
  "version": "1.0.0",
  "private": true,
  "description": "Prototype smart-home demonstrator for assisted living (MQTT, pub/sub, self-announce discovery)",
  "type": "module",
  "scripts": {
    "up": "docker compose up -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f mosquitto",
    "hub": "tsx src/hub/index.ts",
    "web": "tsx src/web/server.ts",
    "sensor": "tsx src/sensors/run.ts",
    "wake": "tsx scripts/wake-offline.ts",
    "seed": "tsx scripts/seed.ts",
    "clear-devices": "tsx scripts/clear-devices.ts",
    "start": "concurrently -n hub,web -c cyan,white \"npm:hub\" \"npm:web\"",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "aedes": "^0.51.3",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
